---
import { actions } from "astro:actions";
import { DashboardContent } from "@/components/dashboard/dashboard-content";
import { Nav } from "@/components/landing/nav";
import BaseLayout from "@/layouts/base-layout.astro";

const { user } = Astro.locals;

// Secondary safety check (middleware already guards this route)
if (!user) {
  return Astro.redirect("/");
}

// Fetch squad using Astro action
const { data } = await Astro.callAction(actions.squad.get, {});
const squad = data?.activeSquad || null;
const allSquads = data?.allSquads || [];

let activeSession: Record<string, any> | null = null;
if (squad) {
  const { data: sessionData } = await Astro.callAction(
    actions.session.getActive,
    {
      squadId: squad.id,
    }
  );
  activeSession = sessionData;
}
---

<BaseLayout
  metadata={{
    title: "Dashboard — Battle Score BR Analytics",
    description: "Panel principal de Battle Score BR Analytics",
    ignoreTitleTemplate: true,
  }}
>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <Nav user={user} client:load />
    <DashboardContent
      squad={squad}
      allSquads={allSquads}
      activeSession={activeSession}
      client:load
    />
  </div>
</BaseLayout>

---
import { actions } from "astro:actions";
import { SquadHubContainer } from "@/components/dashboard/squad-hub";
import { Nav } from "@/components/landing/nav";
import BaseLayout from "@/layouts/base-layout.astro";

const { user } = Astro.locals;

// Secondary safety check (middleware already guards this route)
if (!user) {
  return Astro.redirect("/");
}

// Fetch squads using Astro action
const { data } = await Astro.callAction(actions.squad.getHubData, {});
const squadsList = data || [];
---

<BaseLayout
  metadata={{
    title: "Hub de Escuadrones — Battle Score",
    description: "Hub de escuadrones de Battle Score",
    ignoreTitleTemplate: true,
  }}
>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <Nav user={user} client:load />
    <SquadHubContainer squads={squadsList} currentUser={user} client:load />
  </div>
</BaseLayout>

---
import { actions } from "astro:actions";
import { DashboardContent } from "@/components/dashboard/dashboard-content";
import { Nav } from "@/components/landing/nav";
import BaseLayout from "@/layouts/base-layout.astro";

const { user } = Astro.locals;

// Secondary safety check (middleware already guards this route)
if (!user) {
  return Astro.redirect("/");
}

// Fetch squad using Astro action
const { data: squad } = await Astro.callAction(actions.squad.get, {});
---

<BaseLayout
  metadata={{
    title: "Dashboard — RedSec BR Analytics",
    description: "Panel principal de RedSec BR Analytics",
    ignoreTitleTemplate: true,
  }}
>
  <div class="min-h-screen bg-background text-foreground flex flex-col">
    <Nav user={user} client:load />
    <DashboardContent squad={squad} client:load />
  </div>
</BaseLayout>

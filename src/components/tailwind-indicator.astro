---
const view = import.meta.env.MODE;
---

{view === "development" && (
    <div class="fixed bottom-1 left-1 z-50 flex size-6 items-center justify-center rounded-full bg-gray-800 p-3 font-mono text-xs text-white">
      <div class="block xl:hidden">xs</div>
      <div class="hidden xl:block xl:hidden">sm</div>
      <div class="hidden xl:block xl:hidden">md</div>
      <div class="hidden xl:block xl:hidden">lg</div>
      <div class="hidden xl:block 2xl:hidden">xl</div>
      <div class="hidden 2xl:block">2xl</div>
    </div>
  )}

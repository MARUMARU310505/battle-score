---
import { Hero } from "@/components/landing/hero";
import { Nav } from "@/components/landing/nav";
import BaseLayout from "@/layouts/base-layout.astro";
---

<BaseLayout
  metadata={{
    title: "RedSec BR Analytics — Analiza tu escuadrón",
    description: "Plataforma de análisis de rendimiento para escuadrones competitivos de Battle Royale.",
    ignoreTitleTemplate: true,
  }}
>
  <div
    class="min-h-screen bg-background text-foreground transition-colors duration-200"
  >
    <Nav client:load />
    <main><Hero client:load /></main>
  </div>
</BaseLayout>

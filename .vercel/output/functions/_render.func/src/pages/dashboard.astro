---
import { actions } from "astro:actions";
import { SquadHubContainer } from "@/components/dashboard/squad-hub";
import { Nav } from "@/components/landing/nav";
import BaseLayout from "@/layouts/base-layout.astro";

const { user } = Astro.locals;

// Secondary safety check (middleware already guards this route)
if (!user) {
  return Astro.redirect("/");
}

// Check if user has profile, if not redirect to setup
const { data: profile } = await Astro.callAction(actions.profile.get, {});
if (!profile) {
  return Astro.redirect("/dashboard/profile");
}

// Fetch squads using Astro action
const { data } = await Astro.callAction(actions.squad.getHubData, {});
const squadsList = data || [];
---

<BaseLayout
  metadata={{
    title: "Hub de Escuadrones — Battle Score",
    description: "Hub de escuadrones de Battle Score",
    ignoreTitleTemplate: true,
  }}
>
  <div class="flex flex-1 flex-col">
    <Nav user={user} client:load />
    <SquadHubContainer
      squads={squadsList}
      currentUser={user}
      profile={profile}
      client:load
    />
  </div>
</BaseLayout>
